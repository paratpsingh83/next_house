# ══════════════════════════════════════════════════════════════════════════════
# NexHouse — .env.example
# Copy to .env and fill in your values. NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=nexthouse_db
DB_USERNAME=nexthouse
DB_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── JWT (generate: openssl rand -base64 64) ───────────────────────────────────
JWT_SECRET=REPLACE_WITH_MINIMUM_256_BIT_BASE64_SECRET

# ── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=ap-southeast-1
S3_BUCKET=nexthouse-media
CDN_BASE_URL=https://cdn.nexthouse.app

# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=nexthouse-prod
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# ── PgBouncer (connection pooler) ────────────────────────────────────────────
# Dev: plain text password matches DB_PASSWORD above
# Prod K8s: use SCRAM-SHA-256 hash in pgbouncer-userlist Secret
PGBOUNCER_ADMIN_PASS=change_me_pgbouncer_admin_password

# ── RabbitMQ (WebSocket STOMP broker relay) ──────────────────────────────────
RABBITMQ_USER=nexthouse
RABBITMQ_PASS=change_me_rabbitmq_password

# ── Rate limiting — trusted proxy CIDRs (k8s node/pod CIDRs go here) ─────────
# Only X-Forwarded-For from these ranges is trusted. Defaults cover RFC-1918.
TRUSTED_PROXY_CIDR_1=10.0.0.0/8
TRUSTED_PROXY_CIDR_2=172.16.0.0/12
TRUSTED_PROXY_CIDR_3=192.168.0.0/16

# ── DigiLocker OAuth ─────────────────────────────────────────────────────────
# Sandbox: register at https://partners.digitallocker.gov.in → "Register as Requester Entity"
# Sandbox test: phone=9999999999, OTP=123456
# For local dev use sandbox credentials below.
# For production replace with production credentials from the same portal.
DIGILOCKER_CLIENT_ID=your_sandbox_client_id
DIGILOCKER_CLIENT_SECRET=your_sandbox_client_secret
# Redirect URI must EXACTLY match what you registered on the partner portal
DIGILOCKER_REDIRECT_URI=http://localhost:8080/api/v1/verification/address/digilocker/callback
FRONTEND_URL=http://localhost:3000

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
